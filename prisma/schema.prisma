datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  plan         String   @default("FREE") // "FREE" | "STARTER" | "GROWTH" | "SCALE"
  createdAt    DateTime @default(now())
  apiKeys      ApiKey[]
}

model ApiKey {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyHash   String     @unique
  keyPrefix String     // e.g. "os_" or "od_" (for OmniDetect keys)
  name      String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  usages    ApiUsage[]
}

model ApiUsage {
  id             String   @id @default(uuid())
  apiKeyId       String
  apiKey         ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  endpoint       String   // e.g. "/v1/detect", "/v1/humanize", "/v1/check/plagiarism"
  statusCode     Int
  responseTimeMs Int
  timestamp      DateTime @default(now())
}
